# ============================================================
#  ki_llm_raum – Konfiguration (Beispiel)
#  Kopieren nach .env und anpassen: cp .env.example .env
# ============================================================

# --- Netzwerk ---
SERVER_IP=10.100.1.210
WEBUI_PORT=3000
OLLAMA_PORT=11434
OLLAMA_DOMAIN=ki.deine-firma.info

# --- Zeitzone ---
TIMEZONE=Europe/Berlin
TZ=Europe/Berlin

# --- Ollama ---
OLLAMA_MODEL=llama3.2
OLLAMA_KEEP_ALIVE=5m

# --- Open WebUI ---
WEBUI_AUTH=true
ANONYMIZED_TELEMETRY=false
